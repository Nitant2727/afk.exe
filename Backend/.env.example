# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# --- GitHub OAuth -----------------------------------------------------------
# Create at: github.com -> Settings -> Developer settings -> OAuth Apps -> New
#   Homepage URL:               http://localhost:5173
#   Authorization callback URL: http://localhost:5173/auth/callback
#
# Leave both blank to run without OAuth: the API then advertises a local-only
# sign-in so the dashboard still works for demos.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Server -----------------------------------------------------------------
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-before-anything-leaves-localhost
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --- Database ---------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./afk_monitor.db
